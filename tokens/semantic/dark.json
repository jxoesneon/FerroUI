{
  "color-background":       { "$value": "{gray-900}", "$type": "color" },
  "color-background-subtle":{ "$value": "{gray-800}", "$type": "color" },
  "color-surface":          { "$value": "{gray-800}", "$type": "color" },
  "color-border":           { "$value": "{gray-700}", "$type": "color" },
  "color-text-primary":     { "$value": "{white}",    "$type": "color" },
  "color-text-secondary":   { "$value": "{gray-200}", "$type": "color" },
  "color-text-muted":       { "$value": "{gray-200}", "$type": "color" },
  "color-brand":            { "$value": "{blue-500}", "$type": "color" },
  "color-brand-hover":      { "$value": "{blue-600}", "$type": "color" },
  "color-brand-subtle":     { "$value": "{gray-800}", "$type": "color" },
  "color-error":            { "$value": "{red-500}",  "$type": "color" },
  "color-success":          { "$value": "{green-500}","$type": "color" },
  "color-warning":          { "$value": "{yellow-500}","$type": "color" },
  "space-xs":  { "$value": "{1}",  "$type": "spacing" },
  "space-sm":  { "$value": "{2}",  "$type": "spacing" },
  "space-md":  { "$value": "{4}",  "$type": "spacing" },
  "space-lg":  { "$value": "{6}",  "$type": "spacing" },
  "space-xl":  { "$value": "{8}",  "$type": "spacing" },
  "space-2xl": { "$value": "{12}", "$type": "spacing" },
  "font-body":    { "$value": "{font-family-sans}", "$type": "fontFamily" },
  "font-code":    { "$value": "{font-family-mono}", "$type": "fontFamily" },
  "text-body":    { "$value": "{font-size-base}",   "$type": "fontSize" },
  "text-small":   { "$value": "{font-size-sm}",     "$type": "fontSize" },
  "text-heading": { "$value": "{font-size-2xl}",    "$type": "fontSize" }
}
