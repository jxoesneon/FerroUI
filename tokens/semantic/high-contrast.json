{
  "color-background":       { "$value": "#000000", "$type": "color" },
  "color-background-subtle":{ "$value": "#111111", "$type": "color" },
  "color-surface":          { "$value": "#000000", "$type": "color" },
  "color-border":           { "$value": "#ffffff", "$type": "color" },
  "color-text-primary":     { "$value": "#ffffff", "$type": "color" },
  "color-text-secondary":   { "$value": "#ffffff", "$type": "color" },
  "color-text-muted":       { "$value": "#cccccc", "$type": "color" },
  "color-brand":            { "$value": "#5cb3ff", "$type": "color" },
  "color-brand-hover":      { "$value": "#ffffff", "$type": "color" },
  "color-brand-subtle":     { "$value": "#111111", "$type": "color" },
  "color-error":            { "$value": "#ff6666", "$type": "color" },
  "color-success":          { "$value": "#66ff66", "$type": "color" },
  "color-warning":          { "$value": "#ffff66", "$type": "color" },
  "space-xs":  { "$value": "{1}",  "$type": "spacing" },
  "space-sm":  { "$value": "{2}",  "$type": "spacing" },
  "space-md":  { "$value": "{4}",  "$type": "spacing" },
  "space-lg":  { "$value": "{6}",  "$type": "spacing" },
  "space-xl":  { "$value": "{8}",  "$type": "spacing" },
  "space-2xl": { "$value": "{12}", "$type": "spacing" },
  "font-body":    { "$value": "{font-family-sans}", "$type": "fontFamily" },
  "font-code":    { "$value": "{font-family-mono}", "$type": "fontFamily" },
  "text-body":    { "$value": "{font-size-base}",   "$type": "fontSize" },
  "text-small":   { "$value": "{font-size-sm}",     "$type": "fontSize" },
  "text-heading": { "$value": "{font-size-2xl}",    "$type": "fontSize" }
}
