{
  "color-background":       { "$value": "{white}",    "$type": "color" },
  "color-background-subtle":{ "$value": "{gray-50}",  "$type": "color" },
  "color-surface":          { "$value": "{white}",    "$type": "color" },
  "color-border":           { "$value": "{gray-200}", "$type": "color" },
  "color-text-primary":     { "$value": "{gray-900}", "$type": "color" },
  "color-text-secondary":   { "$value": "{gray-700}", "$type": "color" },
  "color-text-muted":       { "$value": "{gray-600}", "$type": "color" },
  "color-brand":            { "$value": "#0f62fe",    "$type": "color" },
  "color-brand-hover":      { "$value": "#0043ce",    "$type": "color" },
  "color-brand-subtle":     { "$value": "#edf5ff",    "$type": "color" },
  "color-error":            { "$value": "#da1e28",    "$type": "color" },
  "color-success":          { "$value": "#24a148",    "$type": "color" },
  "color-warning":          { "$value": "#f1c21b",    "$type": "color" },
  "space-xs":  { "$value": "{1}",  "$type": "spacing" },
  "space-sm":  { "$value": "{2}",  "$type": "spacing" },
  "space-md":  { "$value": "{4}",  "$type": "spacing" },
  "space-lg":  { "$value": "{6}",  "$type": "spacing" },
  "space-xl":  { "$value": "{8}",  "$type": "spacing" },
  "space-2xl": { "$value": "{12}", "$type": "spacing" },
  "font-body":    { "$value": "'IBM Plex Sans', 'system-ui', sans-serif", "$type": "fontFamily" },
  "font-code":    { "$value": "'IBM Plex Mono', monospace",               "$type": "fontFamily" },
  "text-body":    { "$value": "{font-size-base}",   "$type": "fontSize" },
  "text-small":   { "$value": "{font-size-sm}",     "$type": "fontSize" },
  "text-heading": { "$value": "{font-size-2xl}",    "$type": "fontSize" }
}
