{
  "name": "alloy-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Alloy UI: AI-powered, server-driven UI meta-framework",
  "scripts": {
    "build": "pnpm run -r build",
    "test": "pnpm run -r test",
    "lint": "eslint .",
    "dev": "pnpm run -r dev",
    "typecheck": "tsc --build packages/engine/tsconfig.json",
    "tokens:build": "node --experimental-strip-types scripts/build-tokens.ts",
    "docs:generate": "node --experimental-strip-types scripts/generate-api-docs.ts"
  },
  "keywords": [
    "ai",
    "sdui",
    "framework",
    "react",
    "typescript",
    "llm"
  ],
  "author": "Alloy Project Team",
  "license": "MIT",
  "overrides": {
    "esbuild": "0.18.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eventsource-parser": "^3.0.6",
    "jsdom": "^29.0.2",
    "partial-json-parser": "^1.2.2",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  }
}
