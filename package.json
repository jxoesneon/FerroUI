{
  "name": "alloy-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Alloy UI: AI-powered, server-driven UI meta-framework",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build packages/engine/tsconfig.json && npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "lint": "eslint .",
    "dev": "npm run dev --workspaces --if-present"
  },
  "keywords": [
    "ai",
    "sdui",
    "framework",
    "react",
    "typescript",
    "llm"
  ],
  "author": "Alloy Project Team",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.57.0",
    "eventsource-parser": "^3.0.6",
    "partial-json-parser": "^1.2.2",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.3.6"
  }
}
