{
  "name": "ferroui-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "FerroUI: AI-powered, server-driven UI meta-framework",
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "build": "pnpm run -r build",
    "test": "pnpm run -r test",
    "test:integration": "vitest run --config vitest.config.ts",
    "lint": "eslint .",
    "dev": "pnpm run -r dev",
    "typecheck": "tsc --build packages/engine/tsconfig.json",
    "tokens:build": "node --experimental-strip-types scripts/build-tokens.ts",
    "docs:generate": "node --experimental-strip-types scripts/generate-api-docs.ts",
    "test:a11y": "pnpm run -r test:a11y",
    "lighthouse": "lighthouse http://localhost:3000 --output=json --output-path=./ferroui/evals/lighthouse.json",
    "pa11y": "pa11y http://localhost:3000"
  },
  "keywords": [
    "ferroui",
    "ai",
    "sdui",
    "framework",
    "react",
    "typescript",
    "llm"
  ],
  "author": "FerroUI Project Team",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@changesets/cli": "latest",
    "@chromatic-com/storybook": "^3",
    "@pact-foundation/pact": "^14.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^8.6.12",
    "@storybook/addon-coverage": "^1.0.5",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/addon-interactions": "^8.6.12",
    "@storybook/addon-links": "^8.6.12",
    "@storybook/react": "^8.6.12",
    "@storybook/react-vite": "^8.6.12",
    "@storybook/test": "^8.6.12",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "axe-core": "^4.11.3",
    "chromatic": "^11.28.2",
    "eslint": "^10.2.0",
    "eventsource-parser": "^3.0.6",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.4.0",
    "partial-json-parser": "^1.2.2",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "stryker": "^0.35.1",
    "tailwindcss-logical": "^4.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "dependencies": {
    "puppeteer": "^24.40.0"
  },
  "pnpm": {
    "overrides": {
      "basic-ftp": "^5.3.0",
      "protobufjs": "^8.0.1",
      "typed-rest-client@<1.8.0": ">=1.8.0",
      "log4js@<6.4.0": ">=6.4.0",
      "@stryker-mutator/util@<8.7.1": ">=8.7.1",
      "tmp@<=0.2.3": ">=0.2.4",
      "underscore@>=1.3.2 <1.12.1": ">=1.12.1",
      "underscore@<=1.13.7": ">=1.13.8",
      "flatted@<3.4.0": ">=3.4.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "serialize-javascript@<7.0.5": ">=7.0.5"
    }
  }
}
