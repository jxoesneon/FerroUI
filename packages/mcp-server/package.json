{
  "name": "@ferroui/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Model Context Protocol server exposing FerroUI tools and layout generation to MCP-compatible AI clients.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ferroui-mcp": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@ferroui/engine": "workspace:*",
    "@ferroui/schema": "workspace:*",
    "@ferroui/tools": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
