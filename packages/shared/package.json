{
  "name": "@ferroui/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared utilities, types, and constants for FerroUI UI.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ferroui",
    "shared",
    "utilities"
  ],
  "devDependencies": {
    "@ferroui/config": "workspace:*",
    "tsup": "latest",
    "typescript": "latest"
  }
}
