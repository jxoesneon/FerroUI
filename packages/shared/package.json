{
  "name": "@ferroui/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared utilities, types, and constants for FerroUI.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
